# ============================================
# LARGE DATA FILES - Too big for GitHub
# ============================================
data/images/
data/*.csv
*.csv

# ============================================
# TRAINED MODEL - 31.5MB (use Google Drive)
# ============================================
models/
*.keras
*.h5
*.pkl

# ============================================
# OUTPUT FILES - Can be regenerated
# ============================================
outputs/results/*.pkl
outputs/results/*.json
outputs/results/*.csv

# ============================================
# DATABASE
# ============================================
database/
*.db

# ============================================
# PYTHON CACHE FILES - Auto-generated junk
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python

# ============================================
# JUPYTER NOTEBOOK CHECKPOINTS
# ============================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ============================================
# VIRTUAL ENVIRONMENTS
# ============================================
venv/
env/
.env
*.env

# ============================================
# WINDOWS SYSTEM FILES
# ============================================
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================
# IDE FILES
# ============================================
.vscode/
.idea/
*.suo
*.user

# ============================================
# LOGS
# ============================================
*.log
logs/